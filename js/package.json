{
  "name": "@lessotp/sdk",
  "version": "0.1.0",
  "description": "LessOTP Inbound WhatsApp Authentication client SDK for JavaScript, Bun, and Node.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lessotp/sdk.git",
    "directory": "js"
  },
  "homepage": "https://github.com/lessotp/sdk/tree/main/js#readme",
  "bugs": {
    "url": "https://github.com/lessotp/sdk/issues"
  },
  "keywords": ["lessotp", "whatsapp", "authentication", "verification", "passwordless"],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --target node18",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "bun run lint && bun test && bun run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
